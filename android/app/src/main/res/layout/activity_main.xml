<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Text-to-Image KPI Lab"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- Generated Image Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImagePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generated"
                    android:textSize="11sp"
                    android:textColor="@android:color/darker_gray"
                    android:layout_marginBottom="2dp" />

                <ImageView
                    android:id="@+id/imgGenerated"
                    android:layout_width="match_parent"
                    android:layout_height="256dp"
                    android:scaleType="centerCrop"
                    android:background="#1A000000"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Generated (tap to expand)" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Batch Mode Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <CheckBox
                    android:id="@+id/checkBatchMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Batch Mode (연속 실험)"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/layoutBatchOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Experiment Set"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerExperimentSet"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@android:drawable/btn_dropdown"
                        android:spinnerMode="dropdown" />

                    <LinearLayout
                        android:id="@+id/layoutExperimentDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:background="#F5F5F5">

                        <TextView
                            android:id="@+id/tvExperimentDefaults"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvExperimentList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- SD Config Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSdConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Prompt Input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Prompt"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusBottomEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusTopStart="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPrompt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="a photo of a cat sitting on a windowsill"
                        android:textSize="13sp"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:maxLines="4" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Style Preset -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Style Preset"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true"
                        app:chipSpacingHorizontal="4dp" />

                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tvCombinedPrompt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:maxLines="3"
                    android:ellipsize="end"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <!-- Phase -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Benchmark Phase"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupPhase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioPhase1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phase1: Single Generate (5 trials, cooldown)"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioPhase2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phase2: Sustained Generate (10 trials)" />

                </RadioGroup>

                <!-- Model Variant -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Model Variant"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupVariant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioVariantSd15"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SD v1.5"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioVariantLcm"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LCM-LoRA" />

                </RadioGroup>

                <!-- SD Precision (per-component) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SD Precision (per component)"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="4dp" />

                <!-- Bulk preset buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrecAllFp32"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="All FP32"
                        android:textSize="11sp"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_marginEnd="2dp"
                        app:cornerRadius="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrecAllFp16"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="All FP16"
                        android:textSize="11sp"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_marginHorizontal="2dp"
                        app:cornerRadius="4dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPrecAllW8a8"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="All W8A8"
                        android:textSize="11sp"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_marginStart="2dp"
                        app:cornerRadius="4dp" />

                </LinearLayout>

                <!-- Per-component precision spinners -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tvLabelTextEnc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="Text Enc"
                        android:textSize="12sp"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical" />
                    <Spinner
                        android:id="@+id/spinnerPrecTextEnc"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="UNet"
                        android:textSize="12sp"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical" />
                    <Spinner
                        android:id="@+id/spinnerPrecUnet"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:spinnerMode="dropdown" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_columnWeight="1"
                        android:text="VAE Dec"
                        android:textSize="12sp"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical" />
                    <Spinner
                        android:id="@+id/spinnerPrecVaeDec"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_columnWeight="1"
                        android:spinnerMode="dropdown" />

                </GridLayout>

                <!-- SD Backend (Execution Provider) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Backend"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupEp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioEpNpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NPU"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioEpGpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="GPU" />

                    <RadioButton
                        android:id="@+id/radioEpCpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CPU" />

                </RadioGroup>

                <!-- Steps -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Steps"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioSteps2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="2" />

                    <RadioButton
                        android:id="@+id/radioSteps4"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="4" />

                    <RadioButton
                        android:id="@+id/radioSteps8"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="8" />

                    <RadioButton
                        android:id="@+id/radioSteps20"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="20"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioSteps30"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="30" />

                    <RadioButton
                        android:id="@+id/radioSteps50"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="50" />

                </RadioGroup>

                <!-- Device Model Manager -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageModels"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Manage Models on Device"
                    android:textSize="12sp"
                    android:layout_marginTop="8dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="8dp"
                    app:icon="@android:drawable/ic_menu_manage"
                    app:iconGravity="textStart"
                    app:iconSize="18dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Start Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/start_benchmark"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            app:cornerRadius="8dp" />

        <!-- Batch Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBatchProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/design_default_color_primary"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Batch Progress"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Experiment" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvBatchExperiment" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- / --" android:textColor="@color/text_primary" android:textAlignment="textEnd" />

                </LinearLayout>

                <TextView android:id="@+id/tvCurrentExperiment" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="--" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginBottom="8dp" />

                <LinearLayout android:id="@+id/layoutCooldown" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Cooldown" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvCooldown" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- sec" android:textColor="@color/design_default_color_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <TextView android:id="@+id/tvCompletedExperiments" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="8dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Status -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Status" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvStatus" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Idle" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <ProgressBar android:id="@+id/progressBar" style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="0" android:layout_marginBottom="8dp" android:visibility="gone" />

                <!-- Trial Progress -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Trial" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvTrial" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- / --" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- UNet Step -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="UNet Step" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvUnetStep" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- / --" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- Stage -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Stage" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvStage" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="--" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- E2E Latency -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Generate E2E" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvE2e" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- ms" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- Thermal -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Thermal" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvThermal" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- °C" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- Power -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Power" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvPower" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- mW" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- Memory -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Memory" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvMemory" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- MB" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Export Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExport"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/export_csv"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="8dp" />

    </LinearLayout>

</ScrollView>
