<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Eraser KPI Lab"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="16dp" />

        <!-- Image Selection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelectImage"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Gallery"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginEnd="4dp"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_gallery"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuiltinImage"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Built-in"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_marginStart="4dp"
                app:cornerRadius="8dp"
                app:icon="@android:drawable/ic_menu_slideshow"
                app:iconGravity="textStart" />

        </LinearLayout>

        <!-- Before/After Image Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImagePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/imgBefore"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="Before" />

                <ImageView
                    android:id="@+id/imgAfter"
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_weight="1"
                    android:scaleType="centerCrop"
                    android:layout_marginStart="4dp"
                    android:contentDescription="After" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Batch Mode Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <CheckBox
                    android:id="@+id/checkBatchMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Batch Mode (연속 실험)"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:id="@+id/layoutBatchOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Experiment Set"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerExperimentSet"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@android:drawable/btn_dropdown"
                        android:spinnerMode="dropdown" />

                    <LinearLayout
                        android:id="@+id/layoutExperimentDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:padding="12dp"
                        android:background="#F5F5F5">

                        <TextView
                            android:id="@+id/tvExperimentDefaults"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:id="@+id/tvExperimentList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:fontFamily="monospace"
                            android:lineSpacingExtra="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- SD Config Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSdConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Phase -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Benchmark Phase"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupPhase"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioPhase1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phase1: Single Erase (5 trials, cooldown)"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioPhase2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Phase2: Sustained Erase (10 trials)" />

                    <RadioButton
                        android:id="@+id/radioPhaseYolo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="YOLO-seg Only (20 trials)" />

                </RadioGroup>

                <!-- SD Precision -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SD Precision"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupPrecision"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioPrecFp32"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FP32" />

                    <RadioButton
                        android:id="@+id/radioPrecFp16"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FP16"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioPrecW8a8"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="W8A8" />

                </RadioGroup>

                <!-- SD Backend (Execution Provider) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SD Backend"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupEp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioEpNpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="NPU"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioEpGpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="GPU" />

                    <RadioButton
                        android:id="@+id/radioEpCpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CPU" />

                </RadioGroup>

                <!-- Steps -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Steps"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupSteps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioSteps10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="10" />

                    <RadioButton
                        android:id="@+id/radioSteps20"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="20"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioSteps30"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="30" />

                    <RadioButton
                        android:id="@+id/radioSteps50"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="50" />

                </RadioGroup>

                <!-- Strength -->
                <TextView
                    android:id="@+id/tvStrengthLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Strength: 0.7"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupStrength"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioStr05"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0.5" />

                    <RadioButton
                        android:id="@+id/radioStr07"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0.7"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioStr08"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0.8" />

                    <RadioButton
                        android:id="@+id/radioStr10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1.0" />

                </RadioGroup>

                <!-- ROI Size -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ROI Size"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupRoiSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/radioRoiSmall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Small" />

                    <RadioButton
                        android:id="@+id/radioRoiMedium"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Medium"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/radioRoiLarge"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Large" />

                </RadioGroup>

                <!-- QNN Options -->
                <LinearLayout
                    android:id="@+id/layoutQnnOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <CheckBox
                        android:id="@+id/checkCache"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QNN Context Cache"
                        android:checked="false" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Start Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/start_benchmark"
            android:textSize="16sp"
            android:layout_marginBottom="16dp"
            app:cornerRadius="8dp" />

        <!-- Batch Progress Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBatchProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/design_default_color_primary"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Batch Progress"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Experiment" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvBatchExperiment" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- / --" android:textColor="@color/text_primary" android:textAlignment="textEnd" />

                </LinearLayout>

                <TextView android:id="@+id/tvCurrentExperiment" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="--" android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginBottom="8dp" />

                <LinearLayout android:id="@+id/layoutCooldown" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:visibility="gone">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Cooldown" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvCooldown" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- sec" android:textColor="@color/design_default_color_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <TextView android:id="@+id/tvCompletedExperiments" android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="" android:textColor="@color/text_secondary" android:textSize="11sp" android:layout_marginTop="8dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Status -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Status" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvStatus" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Idle" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <ProgressBar android:id="@+id/progressBar" style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="100" android:progress="0" android:layout_marginBottom="8dp" android:visibility="gone" />

                <!-- Trial Progress -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Trial" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvTrial" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- / --" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- UNet Step -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="UNet Step" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvUnetStep" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- / --" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- Stage -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Stage" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvStage" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="--" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- E2E Latency -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Inpaint E2E" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvE2e" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- ms" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- Thermal -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Thermal" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvThermal" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- °C" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- Power -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Power" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvPower" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- mW" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

                <!-- Memory -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Memory" android:textColor="@color/text_secondary" />
                    <TextView android:id="@+id/tvMemory" android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="-- MB" android:textColor="@color/text_primary" android:textAlignment="textEnd" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Export Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExport"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/export_csv"
            android:textSize="14sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:cornerRadius="8dp" />

    </LinearLayout>

</ScrollView>
