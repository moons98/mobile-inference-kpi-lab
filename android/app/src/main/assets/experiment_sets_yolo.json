{
  "version": 2,
  "defaults": {
    "frequencyHz": 2,
    "durationMinutes": 5,
    "iterations": 100,
    "phase": "BURST",
    "inputMode": "CAMERA_SINGLE",
    "useNpuFp16": false,
    "useContextCache": false,
    "htpPerformanceMode": "burst"
  },
  "experimentSets": [
    {
      "id": "phase1_backend_precision_n",
      "name": "[Phase1] Backend × Precision (YOLOv8n)",
      "experiments": [
        { "model": "YOLOV8N", "executionProvider": "CPU" },
        { "model": "YOLOV8N", "executionProvider": "QNN_GPU" },
        { "model": "YOLOV8N", "executionProvider": "QNN_NPU", "useNpuFp16": true },
        { "model": "YOLOV8N_INT8_QDQ_NOH", "executionProvider": "QNN_NPU", "useNpuFp16": true },
        { "model": "YOLOV8N_INT8_QDQ_PC_NOH", "executionProvider": "QNN_NPU", "useNpuFp16": true }
      ]
    },
    {
      "id": "phase1_backend_precision_s",
      "name": "[Phase1] Backend × Precision (YOLOv8s)",
      "experiments": [
        { "model": "YOLOV8S", "executionProvider": "CPU" },
        { "model": "YOLOV8S", "executionProvider": "QNN_GPU" },
        { "model": "YOLOV8S", "executionProvider": "QNN_NPU", "useNpuFp16": true },
        { "model": "YOLOV8S_INT8_QDQ_NOH", "executionProvider": "QNN_NPU", "useNpuFp16": true },
        { "model": "YOLOV8S_INT8_QDQ_PC_NOH", "executionProvider": "QNN_NPU", "useNpuFp16": true }
      ]
