        { "model": "YOLOV8M", "executionProvider": "QNN_GPU" },
        { "model": "YOLOV8M", "executionProvider": "QNN_NPU", "useNpuFp16": true },
        { "model": "YOLOV8M_INT8_QDQ_NOH", "executionProvider": "QNN_NPU", "useNpuFp16": true },
        { "model": "YOLOV8M_INT8_QDQ_PC_NOH", "executionProvider": "QNN_NPU", "useNpuFp16": true }
      ]
    },
    {
      "id": "phase1_model_scale",
      "name": "[Phase1] Model Scale (n/s/m, INT8 PC+NoHead)",
      "experiments": [
        { "model": "YOLOV8N_INT8_QDQ_PC_NOH", "executionProvider": "QNN_NPU", "useNpuFp16": true },
        { "model": "YOLOV8S_INT8_QDQ_PC_NOH", "executionProvider": "QNN_NPU", "useNpuFp16": true },
