{
  "version": 2,
  "defaults": {
    "phase": "SINGLE_GENERATE",
    "modelVariant": "SD_V15",
    "steps": 20,
    "guidanceScale": 7.5,
    "prompt": "a photo of a cat sitting on a windowsill",
    "trials": 5,
    "warmupTrials": 2,
    "useNpuFp16": true,
    "htpPerformanceMode": "burst",
    "parallelInit": false,
    "modelDir": "/sdcard/sd_models"
  },
  "experimentSets": [
    {
      "id": "phase1_precision_sd15",
      "name": "[Phase1] Precision — SD v1.5 (A1~A4)",
      "experiments": [
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "steps": 20 },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "steps": 20, "precUnet": "MIXED_PR" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "steps": 20, "precVaeDec": "W8A8" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "steps": 20, "precUnet": "MIXED_PR", "precVaeDec": "W8A8" }
      ]
    },
    {
      "id": "phase1_precision_lcm",
      "name": "[Phase1] Precision — LCM (A5~A6)",
      "experiments": [
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "modelVariant": "LCM_LORA", "steps": 4, "guidanceScale": 1.0 },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "modelVariant": "LCM_LORA", "steps": 4, "guidanceScale": 1.0, "precVaeDec": "W8A8" }
      ]
    },
    {
      "id": "phase2_step_sd15",
      "name": "[Phase2] Step Sweep — SD v1.5 (B1~B2)",
      "experiments": [
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "steps": 30 },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "steps": 50 }
      ]
    },
    {
      "id": "phase2_step_lcm",
      "name": "[Phase2] Step Sweep — LCM (B3)",
      "experiments": [
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "modelVariant": "LCM_LORA", "steps": 8, "guidanceScale": 1.0 }
      ]
    }
  ]
}
