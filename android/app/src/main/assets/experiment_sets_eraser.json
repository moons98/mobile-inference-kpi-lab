{
  "version": 3,
  "defaults": {
    "phase": "SINGLE_ERASE",
    "steps": 20,
    "strength": 0.7,
    "roiSize": "MEDIUM",
    "roiPaddingRatio": 1.5,
    "trials": 5,
    "warmupTrials": 2,
    "useNpuFp16": true,
    "useContextCache": false,
    "htpPerformanceMode": "burst",
    "modelDir": "/sdcard/sd_models",
    "yoloBackend": "QNN_NPU",
    "yoloPrecision": "FP32"
  },
  "experimentSets": [
    {
      "id": "exp1_inpaint_backend_precision",
      "name": "[Exp1] Inpainting Backend × Precision",
      "experiments": [
        { "sdBackend": "CPU", "sdPrecision": "FP32", "useNpuFp16": false, "trials": 1 },
        { "sdBackend": "QNN_GPU", "sdPrecision": "FP16" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8" }
      ]
    },
    {
      "id": "exp2_yolo_backend_precision",
      "name": "[Exp2] YOLO-seg Backend × Precision",
      "experiments": [
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "phase": "YOLO_SEG_ONLY", "yoloBackend": "CPU", "yoloPrecision": "FP32" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "phase": "YOLO_SEG_ONLY", "yoloBackend": "QNN_GPU", "yoloPrecision": "FP32" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "phase": "YOLO_SEG_ONLY", "yoloBackend": "QNN_NPU", "yoloPrecision": "FP32" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "phase": "YOLO_SEG_ONLY", "yoloBackend": "QNN_NPU", "yoloPrecision": "INT8" }
      ]
    },
    {
      "id": "exp3_steps_strength",
      "name": "[Exp3] Step × Strength",
      "experiments": [
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "strength": 0.5 },
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "strength": 0.7 },
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "strength": 0.8 },
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "strength": 1.0 },
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "steps": 50, "strength": 0.7 }
      ]
    },
    {
      "id": "exp4_roi_size",
      "name": "[Exp4] ROI Size",
      "experiments": [
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "roiSize": "SMALL" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "roiSize": "MEDIUM" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "roiSize": "LARGE" }
      ]
    },
    {
      "id": "phase2_sustained",
      "name": "[Phase2] Sustained Erase",
      "experiments": [
        { "sdBackend": "QNN_NPU", "sdPrecision": "W8A8", "phase": "SUSTAINED_ERASE", "trials": 10, "htpPerformanceMode": "sustained_high" },
        { "sdBackend": "QNN_NPU", "sdPrecision": "FP16", "phase": "SUSTAINED_ERASE", "trials": 10, "htpPerformanceMode": "sustained_high" },
        { "sdBackend": "QNN_GPU", "sdPrecision": "FP16", "phase": "SUSTAINED_ERASE", "trials": 10, "htpPerformanceMode": "sustained_high" }
      ]
    }
  ]
}
